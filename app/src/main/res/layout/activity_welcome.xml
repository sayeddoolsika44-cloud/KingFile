<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="centerCrop" android:src="@drawable/warrior_bg" android:alpha="0.75"/>

    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#660A0A12"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom" android:orientation="vertical"
        android:gravity="center" android:paddingStart="28dp" android:paddingEnd="28dp"
        android:paddingBottom="52dp" android:paddingTop="20dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:background="#AA0A0A20" android:padding="22dp"
            android:layout_marginBottom="20dp">

            <TextView android:id="@+id/ownerName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/owner" android:textSize="28sp" android:textStyle="bold"
                android:textColor="@color/neon_blue" android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" android:alpha="0"/>

            <View android:layout_width="100dp" android:layout_height="1dp"
                android:background="#3300CCFF" android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/appTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="King File" android:textSize="20sp" android:textStyle="bold"
                android:textColor="@color/neon_red" android:letterSpacing="0.2"
                android:alpha="0"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startBtn"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:text="@string/start_king" android:textSize="18sp" android:textStyle="bold"
            android:textColor="@color/white" android:letterSpacing="0.12"
            app:backgroundTint="#FF0055CC" app:cornerRadius="27dp"
            android:alpha="0"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/copyright" android:textSize="8sp"
            android:textColor="#44FFFFFF" android:gravity="center"
            android:layout_marginTop="12dp" android:singleLine="true"
            android:ellipsize="end"/>
    </LinearLayout>
</FrameLayout>
